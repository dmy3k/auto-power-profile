#: extension.js:64
#, fuzzy
msgid "Error connecting to power management services"
msgstr "power-profiles-daemon DBus'a bağlanırken hata oluştu"

#: extension.js:155
#, javascript-format
msgid ""
"Power profile '%s' will now be used by default when connected to AC power"
msgstr "Fişe takılıyken '%s' güç profili öntanımlı olarak kullanılacak"

#: extension.js:163
#, javascript-format
msgid "Power profile '%s' will now be used by default when running on battery"
msgstr "Pildeyken '%s' güç profili öntanımlı olarak kullanılacak"

#: extension.js:294
msgid ""
"Low power adapter detected. Switched to Power Saver — charging will resume "
"in a few seconds"
msgstr ""

#: extension.js:398
msgid ""
"Power profile management is not available - this extension will have no "
"effect on your system"
msgstr ""
"Güç profili yönetimi kullanılamıyor - bu uzantının sisteminizde hiçbir "
"etkisi olmayacak"

#: extension.js:404
msgid ""
"Power profile switching may not work properly on this device - energy "
"savings will be limited. Your system may need updates to enable full "
"functionality"
msgstr ""
"Bu aygıtta güç profili değiştirme düzgün çalışmayabilir - enerji tasarrufu "
"sınırlı olacaktır. Tam işlevselliği etkinleştirmek için sisteminiz "
"güncellemeler gerektirebilir"

