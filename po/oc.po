#: extension.js:64
msgid "Error connecting to power management services"
msgstr "Error en se connectant als servicis de gestion de l'alimentacion"

#: extension.js:155
#, javascript-format
msgid ""
"Power profile '%s' will now be used by default when connected to AC power"
msgstr ""
"Lo perfil d'energia « %s » serà ara utilizat per defaut en foncionament sus "
"sector"

#: extension.js:163
#, javascript-format
msgid "Power profile '%s' will now be used by default when running on battery"
msgstr ""
"Lo perfil d'energia « %s » serà ara utilizat per defaut en foncionament sus "
"batariá"

#: extension.js:294
msgid ""
"Low power adapter detected. Switched to Power Saver — charging will resume "
"in a few seconds"
msgstr ""

#: extension.js:398
msgid ""
"Power profile management is not available - this extension will have no "
"effect on your system"
msgstr ""
"La gestion dels perfils d'energia es pas disponibla - aquesta extension aurà "
"pas cap d'efièch sus vòstre sistèma"

#: extension.js:404
msgid ""
"Power profile switching may not work properly on this device - energy "
"savings will be limited. Your system may need updates to enable full "
"functionality"
msgstr ""
"Lo cambiament de perfil d'energia poiriá non pas foncionar corrèctament sus "
"aqueste periferic - las economias d'energia seràn limitadas. Vòstre sistèma "
"poiriá requerir de mesas a jorn per activar la plena foncionalitat"

