#: extension.js:64
#, fuzzy
msgid "Error connecting to power management services"
msgstr "Error al conectar con el DBus de power-profiles-daemon"

#: extension.js:155
#, javascript-format
msgid ""
"Power profile '%s' will now be used by default when connected to AC power"
msgstr ""
"El perfil de energía '%s' se usará por defecto al conectar la alimentación"

#: extension.js:163
#, javascript-format
msgid "Power profile '%s' will now be used by default when running on battery"
msgstr ""
"El perfil de energía '%s' se usará por defecto al funcionar con batería"

#: extension.js:294
msgid ""
"Low power adapter detected. Switched to Power Saver — charging will resume "
"in a few seconds"
msgstr ""

#: extension.js:398
msgid ""
"Power profile management is not available - this extension will have no "
"effect on your system"
msgstr ""
"La gestión de perfiles de energía no está disponible - esta extensión no "
"tendrá efecto en su sistema"

#: extension.js:404
msgid ""
"Power profile switching may not work properly on this device - energy "
"savings will be limited. Your system may need updates to enable full "
"functionality"
msgstr ""
"El cambio de perfil de energía puede no funcionar correctamente en este "
"dispositivo - el ahorro de energía será limitado. Su sistema puede necesitar "
"actualizaciones para habilitar la funcionalidad completa"

#: prefs.js:68 ui/general.ui:5
msgid "General"
msgstr "General"

