#: extension.js:64
#, fuzzy
msgid "Error connecting to power management services"
msgstr "Помилка з'єднання з power-profiles-daemon DBus"

#: extension.js:155
#, javascript-format
msgid ""
"Power profile '%s' will now be used by default when connected to AC power"
msgstr "Профіль '%s' тепер буде використовуватися за замовчуванням від мережі"

#: extension.js:163
#, javascript-format
msgid "Power profile '%s' will now be used by default when running on battery"
msgstr "Профіль '%s' тепер буде використовуватися за замовчуванням від батареї"

#: extension.js:294
msgid ""
"Low power adapter detected. Switched to Power Saver — charging will resume "
"in a few seconds"
msgstr ""

#: extension.js:398
msgid ""
"Power profile management is not available - this extension will have no "
"effect on your system"
msgstr ""
"Керування профілями живлення недоступне - це розширення не матиме жодного "
"впливу на вашу систему"

#: extension.js:404
msgid ""
"Power profile switching may not work properly on this device - energy "
"savings will be limited. Your system may need updates to enable full "
"functionality"
msgstr ""
"Перемикання профілів живлення може працювати неправильно на цьому пристрої - "
"економія енергії буде обмеженою. Вашій системі можуть знадобитися оновлення "
"для забезпечення повної функціональності"

