msgstr ""

#: prefs.js:274
msgid ""
"Addresses quirks found on certain hardware configurations. Enable only if "
"the described issue applies to your setup."
msgstr ""

#: prefs.js:288
msgid "Underpowered Adapter Handling"
msgstr ""

#: prefs.js:290
msgid ""
"Switch to Power Saver when adapter is connected but battery is discharging "
"under load. Resets when adapter is unplugged."
msgstr ""

#: prefs.js:312
msgid "Performance"
msgstr "Швидкодія"

#: prefs.js:313
msgid "Balanced"
msgstr "Баланс"

#: prefs.js:314
msgid "Power Saver"
msgstr "Заощадження"

#: ui/general.ui:9
msgid "Default Profiles"
msgstr "За замовчуванням"

#: ui/general.ui:10
msgid "Applied automatically unless user sets manually another one"
msgstr "Застосовуються автоматично якшо не обрано вручну користувачем"

#: ui/general.ui:15
msgid "Select the default profile when connected to AC"
msgstr "Профіль за замовчуванням від мережі"

#: ui/general.ui:23
msgid "Select the default profile when running on battery"
msgstr "Профіль за замовчуванням від батареї"

#: ui/general.ui:30
msgid "Low Battery Threshold"
msgstr "Поріг низького заряду батареї"

#: ui/general.ui:31
msgid "Automatic power-saver on low battery"
msgstr "Автоматичне заощадження при низькому заряді"

#: ui/general.ui:43
msgid ""
"Enable/disable in GNOME Settings → Power → Power Saving Options. The "
"percentage threshold value is configured in the UPower config file (/etc/"
"UPower/UPower.conf)"
msgstr ""
"Увімкнути/вимкнути в Налаштуваннях GNOME → Живлення → Параметри "
"енергозбереження. Значення порогу у відсотках налаштовується у файлі "
"конфігурації UPower (/etc/UPower/UPower.conf)"

#: ui/general.ui:60
msgid "Remember manual profile changes"
msgstr "Запам'ятовувати ручні зміни профілю"

#: ui/general.ui:61
msgid ""
"When enabled, manually selected profiles become the new default for the "
"current power state. When disabled, manual changes are temporary"
msgstr ""
"Коли увімкнено, профілі, обрані вручну, стають новими за замовчуванням для "
"поточного стану живлення. Коли вимкнено, ручні зміни є тимчасовими"

#: ui/general.ui:73
msgid "Notifications"
msgstr "Показувати сповіщення"

#: ui/general.ui:74
msgid "Allow extension notifications"
msgstr "Показувати сповіщення розширення"

